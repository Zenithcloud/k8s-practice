apiVersion: v1
kind: Pod
metadata:
 name: initcontainer
spec:
 volumes: 
 - name: work
   emptyDir: {}

 initContainers:
 - name: init-conta
   image: busybox:1.36
   command: ["sh","-c"]
   args:
     - echo "Created by init at $(date)" > /work/init.txt
   volumeMounts:
   - name: work
     mountPath: /work

 containers:
 - name: app
   image: nginx
   volumeMounts:
   - name: work
     mountPath: /work